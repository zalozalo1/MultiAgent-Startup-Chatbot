# --- Backend ---------------------------------------------------------------
# SQLAlchemy async URL (asyncpg driver). Matches docker-compose defaults.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/startup_research
# JSON list of allowed frontend origins.
CORS_ORIGINS=["http://localhost:3000"]

# --- AI engine ---------------------------------------------------------------
# Default chat model in "provider:model" form.
AI_MODEL=openai:gpt-5-mini
OPENAI_API_KEY=sk-...
# Or use Anthropic:
# AI_MODEL=anthropic:claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...
# Or use OpenRouter (OpenAI-compatible routing):
# AI_MODEL=openrouter:openai/gpt-5-mini
# OPENROUTER_API_KEY=sk-or-...

# Optional: higher-quality web search (falls back to DuckDuckGo without it).
# TAVILY_API_KEY=tvly-...

# Optional: durable conversation memory across backend restarts.
# AI_CHECKPOINTER=postgres
# AI_CHECKPOINTER_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/startup_research
