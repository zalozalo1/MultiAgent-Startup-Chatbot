# Default direct-provider model.
# AI_MODEL=openai:gpt-5-mini
# OPENAI_API_KEY=sk-...

# OpenRouter model routing.
AI_MODEL=openrouter:openai/gpt-5-mini
OPENROUTER_API_KEY=sk-or-...

# Google Gemini direct provider.
# AI_MODEL=google_genai:gemini-2.5-flash
# GOOGLE_API_KEY=AIza...

# Anthropic direct provider.
# AI_MODEL=anthropic:claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# Optional web search provider. If omitted, the app falls back to DuckDuckGo.
# TAVILY_API_KEY=tvly-...

# Safety valve for each specialist agent's internal tool-calling loop.
AI_AGENT_RECURSION_LIMIT=50

# Optional durable LangGraph memory.
# AI_CHECKPOINTER=postgres
# AI_CHECKPOINTER_POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/startup_research
